{
  "name": "@xgent-ai/gomad",
  "version": "1.0.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },  
  "description": "One command installs curated Claude Code skills, agents, rules, hooks, and commands into your project's local .claude/ directory.",
  "type": "module",
  "bin": {
    "gomad": "bin/gomad-cli.js"
  },
  "scripts": {
    "test": "node --test --test-timeout=120000 'test/test-*.js'",
    "curate": "node tools/curator.js",
    "lint": "npx eslint ."
  },
  "keywords": [
    "gomad",
    "claude-code",
    "ai-development",
    "skills",
    "agents"
  ],
  "author": "Rockie Guo <rockie@kitmi.com.au>",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^13.1.0",
    "yaml": "^2.7.1",
    "fs-extra": "^11.3.0",
    "chalk": "^5.4.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "assets/",
    "catalog/",
    "tools/",
    "README.md"
  ]
}
